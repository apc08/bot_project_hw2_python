# Dockerfile для Telegram Bot
FROM python:3.11-slim

WORKDIR /app

# Установить uv для быстрой установки зависимостей
RUN pip install --no-cache-dir uv

# Копировать файлы проекта
COPY pyproject.toml .
COPY app/ ./app/
COPY bot.py .

# Установить зависимости через uv
RUN uv pip install --system --no-cache -e .

# Запустить Telegram Bot
CMD ["python", "bot.py"]
